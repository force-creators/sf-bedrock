---
import '../styles/docs-layout.css';
import { navGroups, type SectionLink } from '../data/docs-navigation';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  heading?: string;
  lede?: string;
  sections?: SectionLink[];
}

interface SearchEntry {
  title: string;
  href: string;
  category: string;
  description: string;
  body: string;
  keywords: string;
}

const propsSource: Props = (Astro.props.frontmatter ?? Astro.props) as Props;

const {
  title,
  description = 'Technical documentation for sf-bedrock.',
  eyebrow = 'Documentation',
  heading,
  lede,
  sections = []
} = propsSource;

const hasHeaderSlot = Astro.slots.has('header');

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => href !== '#' && (href.replace(/\/$/, '') || '/') === currentPath;

const pageModules = import.meta.glob('../pages/*.md', { eager: true });
const pageSources = import.meta.glob('../pages/*.{astro,md}', {
  eager: true,
  import: 'default',
  query: '?raw'
});

const pagePathToHref = (path: string) => {
  const pageName = path.split('/').pop()?.replace(/\.(astro|md)$/, '') ?? '';
  return pageName === 'index' ? '/' : `/${pageName}`;
};

const pageTitle = (page: Partial<Props>, fallback: string) =>
  (page.heading || page.title || fallback).replace(/\s+\|\s+sf-bedrock docs$/, '');

const textFromSource = (source: string) =>
  source
    .replace(/^---[\s\S]*?---/, ' ')
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/\[[^\]]+\]\(([^)]+)\)/g, ' ')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/<script[\s\S]*?<\/script>/gi, ' ')
    .replace(/<style[\s\S]*?<\/style>/gi, ' ')
    .replace(/<[^>]+>/g, ' ')
    .replace(/\{[\s\S]*?\}/g, ' ')
    .replace(/[#*_>|-]+/g, ' ')
    .replace(/&nbsp;/g, ' ')
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/\s+/g, ' ')
    .trim();

const pageMetadata = new Map<string, Partial<Props>>();
const pageText = new Map<string, string>();

for (const [path, pageModule] of Object.entries(pageModules)) {
  const frontmatter = (pageModule as { frontmatter?: Partial<Props> }).frontmatter;
  if (frontmatter) {
    pageMetadata.set(pagePathToHref(path), frontmatter);
  }
}

for (const [path, source] of Object.entries(pageSources)) {
  pageText.set(pagePathToHref(path), textFromSource(source as string));
}

pageMetadata.set('/', {
  title: 'sf-bedrock',
  description: 'Salesforce architecture toolkit docs for scalable async work, dependency injection, and database-free Apex tests.',
  eyebrow: 'Start'
});

pageMetadata.set('/getting-started', {
  title: 'Getting Started',
  description: 'Start building with sf-bedrock by installing the unlocked package or cloning the source, then adopting the smallest useful tools before the larger frameworks.',
  eyebrow: 'Start'
});

const searchEntries: SearchEntry[] = [];

for (const group of navGroups) {
  for (const item of group.items) {
    if (item.href === '#') {
      continue;
    }

    const href = item.href.replace(/\/$/, '') || '/';
    const metadata = pageMetadata.get(href) ?? {};
    const titleText = pageTitle(metadata, item.label);
    const descriptionText = metadata.description || metadata.lede || '';
    const categoryText = metadata.eyebrow || group.label;
    const sectionKeywords = (metadata.sections ?? []).map((section) => section.label).join(' ');
    const bodyText = pageText.get(href) || '';

    searchEntries.push({
      title: titleText,
      href,
      category: categoryText,
      description: descriptionText,
      body: bodyText,
      keywords: `${item.label} ${titleText} ${categoryText} ${descriptionText} ${sectionKeywords} ${bodyText}`
    });

    for (const section of metadata.sections ?? []) {
      searchEntries.push({
        title: `${titleText}: ${section.label}`,
        href: `${href === '/' ? '' : href}${section.href}`,
        category: `${categoryText} section`,
        description: descriptionText,
        body: '',
        keywords: `${item.label} ${titleText} ${section.label} ${categoryText} ${descriptionText}`
      });
    }
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/icon.ico" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="release-banner" role="note">
      <span>Pre-release: sf-bedrock is under active development. APIs and docs may change before general availability.</span>
    </div>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/">
          <img class="brand-logo" src="/icon.svg" alt="" />
          <span class="brand-text">Bedrock Docs</span>
        </a>
        <div class="top-actions">
          <form class="search" role="search" aria-label="Documentation search" data-docs-search>
            <label class="visually-hidden" for="docs-search-input">Search docs</label>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="m20 20-4.2-4.2m1.4-5.1a6.2 6.2 0 1 1-12.4 0 6.2 6.2 0 0 1 12.4 0Z"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              />
            </svg>
            <input
              id="docs-search-input"
              class="search-input"
              type="search"
              placeholder="Search docs"
              autocomplete="off"
              spellcheck="false"
              aria-controls="docs-search-results"
              aria-expanded="false"
            />
            <button class="search-clear" type="button" aria-label="Clear search" hidden>
              <span aria-hidden="true"></span>
              <span aria-hidden="true"></span>
            </button>
            <div class="search-popover" id="docs-search-results" role="listbox" hidden>
              <p class="search-empty" data-search-empty>No matching docs.</p>
              <ul class="search-results" data-search-results></ul>
            </div>
          </form>
          <button
            class="menu-toggle"
            type="button"
            aria-label="Open documentation menu"
            aria-controls="docs-sidebar"
            aria-expanded="false"
          >
            <span class="menu-toggle-icon" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </span>
            <span class="menu-toggle-text">Menu</span>
          </button>
          <a class="header-link" href="https://github.com/force-creators/sf-bedrock" target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M7 17 17 7M9 7h8v8"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            Repository
          </a>
        </div>
      </div>
    </header>

    <div class="layout">
      <aside class="sidebar" id="docs-sidebar" aria-label="Documentation navigation">
        <div class="sidebar-header">
          <span class="sidebar-title">Documentation</span>
          <button class="menu-close" type="button" aria-label="Close documentation menu" aria-controls="docs-sidebar">
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </button>
        </div>
        <nav class="sidebar-inner">
          {
            navGroups.map((group) => (
              <section class="nav-group" aria-labelledby={`nav-${group.label.toLowerCase()}`}>
                <h2 class="nav-heading" id={`nav-${group.label.toLowerCase()}`}>{group.label}</h2>
                <ul class="nav-list">
                  {
                    group.items.map((item) => (
                      <li>
                        {
                          item.href === '#' ? (
                            <span class="nav-link nav-link-disabled" aria-disabled="true">
                              <span>{item.label}</span>
                              {item.status && <span class="status">{item.status}</span>}
                            </span>
                          ) : (
                            <a
                              class="nav-link"
                              href={item.href}
                              aria-current={isActive(item.href) ? 'page' : undefined}
                            >
                              <span>{item.label}</span>
                              {item.status && <span class="status">{item.status}</span>}
                            </a>
                          )
                        }
                        {isActive(item.href) && sections.length > 0 && (
                          <ul class="nav-sublist">
                            {sections.map((section) => (
                              <li>
                                <a class="nav-sublink" href={section.href}>{section.label}</a>
                              </li>
                            ))}
                          </ul>
                        )}
                      </li>
                    ))
                  }
                </ul>
              </section>
            ))
          }
        </nav>
      </aside>
      <button class="sidebar-backdrop" type="button" aria-label="Dismiss documentation menu" hidden></button>

      <main class="content-wrap">
        <article class="content">
          <header class="article-header">
            <div class="article-kicker">{eyebrow}</div>
            {
              hasHeaderSlot ? (
                <slot name="header" />
              ) : (
                <Fragment>
                  <h1 class="page-title">{heading ?? title}</h1>
                  {lede && <p class="lede">{lede}</p>}
                </Fragment>
              )
            }
          </header>
          <slot />
        </article>
        <footer class="site-footer">A technical documentation workspace for human-maintainable Salesforce architecture.</footer>
      </main>
    </div>

    <script id="docs-search-index" type="application/json" set:html={JSON.stringify(searchEntries)}></script>
    <script>
      (() => {
        const sidebar = document.querySelector('#docs-sidebar');
        const menuButton = document.querySelector('.menu-toggle');
        const closeButton = document.querySelector('.menu-close');
        const backdrop = document.querySelector('.sidebar-backdrop');
        const mobileNavigation = window.matchMedia('(max-width: 1020px)');
        const searchRoot = document.querySelector('[data-docs-search]');
        const searchInput = searchRoot?.querySelector('.search-input');
        const searchClear = searchRoot?.querySelector('.search-clear');
        const searchPopover = searchRoot?.querySelector('.search-popover');
        const searchResults = searchRoot?.querySelector('[data-search-results]');
        const searchEmpty = searchRoot?.querySelector('[data-search-empty]');
        const searchIndexElement = document.querySelector('#docs-search-index');
        const searchIndex = JSON.parse(searchIndexElement?.textContent || '[]');

        const closeMenu = () => {
          document.body.classList.remove('nav-open');
          menuButton?.setAttribute('aria-expanded', 'false');
          menuButton?.setAttribute('aria-label', 'Open documentation menu');
          if (backdrop instanceof HTMLElement) {
            backdrop.hidden = true;
          }
        };

        const openMenu = () => {
          document.body.classList.add('nav-open');
          menuButton?.setAttribute('aria-expanded', 'true');
          menuButton?.setAttribute('aria-label', 'Close documentation menu from header');
          if (backdrop instanceof HTMLElement) {
            backdrop.hidden = false;
          }
          closeButton?.focus();
        };

        menuButton?.addEventListener('click', () => {
          if (document.body.classList.contains('nav-open')) {
            closeMenu();
          } else {
            openMenu();
          }
        });

        closeButton?.addEventListener('click', closeMenu);
        backdrop?.addEventListener('click', closeMenu);

        sidebar?.addEventListener('click', (event) => {
          const link = event.target instanceof Element ? event.target.closest('a') : null;
          if (link && mobileNavigation.matches) {
            closeMenu();
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && document.body.classList.contains('nav-open')) {
            closeMenu();
            menuButton?.focus();
          }
        });

        mobileNavigation.addEventListener('change', (event) => {
          if (!event.matches) {
            closeMenu();
          }
        });

        const normalizeSearch = (value) => value.toLowerCase().replace(/\s+/g, ' ').trim();

        const closeSearch = () => {
          searchPopover?.setAttribute('hidden', '');
          searchInput?.setAttribute('aria-expanded', 'false');
        };

        const openSearch = () => {
          searchPopover?.removeAttribute('hidden');
          searchInput?.setAttribute('aria-expanded', 'true');
        };

        const scoreSearchEntry = (entry, query, tokens) => {
          const title = normalizeSearch(entry.title);
          const category = normalizeSearch(entry.category);
          const description = normalizeSearch(entry.description);
          const body = normalizeSearch(entry.body || '');
          const keywords = normalizeSearch(entry.keywords);

          if (!tokens.every((token) => keywords.includes(token))) {
            return 0;
          }

          let score = 10;

          if (title === query) {
            score += 80;
          } else if (title.startsWith(query)) {
            score += 60;
          } else if (title.includes(query)) {
            score += 40;
          }

          if (category.includes(query)) {
            score += 20;
          }

          if (description.includes(query)) {
            score += 10;
          }

          if (body.includes(query)) {
            score += 8;
          }

          return score;
        };

        const resultExcerpt = (entry, query, tokens) => {
          const text = [entry.description, entry.body].filter(Boolean).join(' ');
          if (!text) {
            return '';
          }

          const normalizedText = normalizeSearch(text);
          const normalizedQuery = normalizeSearch(query);
          let matchIndex = normalizedText.indexOf(normalizedQuery);

          if (matchIndex < 0) {
            matchIndex = tokens
              .map((token) => normalizedText.indexOf(token))
              .filter((index) => index >= 0)
              .sort((left, right) => left - right)[0] ?? 0;
          }

          const start = Math.max(0, matchIndex - 90);
          const end = Math.min(text.length, matchIndex + normalizedQuery.length + 130);
          const prefix = start > 0 ? '...' : '';
          const suffix = end < text.length ? '...' : '';

          return `${prefix}${text.slice(start, end).trim()}${suffix}`;
        };

        const findSearchResults = (query) => {
          const normalizedQuery = normalizeSearch(query);
          if (normalizedQuery.length < 2) {
            return [];
          }

          const tokens = normalizedQuery.split(' ');

          return searchIndex
            .map((entry) => ({
              entry: {
                ...entry,
                excerpt: resultExcerpt(entry, normalizedQuery, tokens)
              },
              score: scoreSearchEntry(entry, normalizedQuery, tokens)
            }))
            .filter((result) => result.score > 0)
            .sort((left, right) => right.score - left.score || left.entry.title.localeCompare(right.entry.title))
            .slice(0, 12)
            .map((result) => result.entry);
        };

        const renderSearchResults = () => {
          if (!(searchInput instanceof HTMLInputElement) || !(searchResults instanceof HTMLElement)) {
            return;
          }

          const results = findSearchResults(searchInput.value);
          searchResults.replaceChildren();
          searchClear?.toggleAttribute('hidden', searchInput.value.length === 0);

          if (normalizeSearch(searchInput.value).length < 2) {
            closeSearch();
            return;
          }

          if (searchEmpty instanceof HTMLElement) {
            searchEmpty.hidden = results.length > 0;
          }

          for (const result of results) {
            const item = document.createElement('li');
            const link = document.createElement('a');
            const titleElement = document.createElement('span');
            const categoryElement = document.createElement('span');
            const excerptElement = document.createElement('span');

            link.className = 'search-result';
            link.href = result.href;
            link.setAttribute('role', 'option');
            titleElement.className = 'search-result-title';
            titleElement.textContent = result.title;
            categoryElement.className = 'search-result-meta';
            categoryElement.textContent = result.category;
            excerptElement.className = 'search-result-excerpt';
            excerptElement.textContent = result.excerpt || result.description;

            link.append(titleElement, categoryElement);
            if (excerptElement.textContent) {
              link.append(excerptElement);
            }
            item.append(link);
            searchResults.append(item);
          }

          openSearch();
        };

        searchInput?.addEventListener('input', renderSearchResults);
        searchInput?.addEventListener('focus', renderSearchResults);

        searchClear?.addEventListener('click', () => {
          if (!(searchInput instanceof HTMLInputElement)) {
            return;
          }

          searchInput.value = '';
          searchInput.focus();
          renderSearchResults();
        });

        searchRoot?.addEventListener('submit', (event) => {
          event.preventDefault();
          const firstResult = searchResults?.querySelector('a');
          if (firstResult instanceof HTMLAnchorElement) {
            window.location.href = firstResult.href;
          }
        });

        document.addEventListener('click', (event) => {
          if (event.target instanceof Node && !searchRoot?.contains(event.target)) {
            closeSearch();
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            closeSearch();
          }
        });

        const sectionLinks = Array.from(
          document.querySelectorAll('.nav-sublink[href^="#"], .toc-link[href^="#"]')
        );

        if (sectionLinks.length === 0) {
          return;
        }

        const normalizeHash = (value) => {
          if (!value || !value.startsWith('#')) {
            return '';
          }

          try {
            return `#${decodeURIComponent(value.slice(1))}`;
          } catch {
            return value;
          }
        };

        const linkMap = new Map();
        for (const link of sectionLinks) {
          const hash = normalizeHash(link.getAttribute('href') || '');
          if (!hash) {
            continue;
          }

          const linksForHash = linkMap.get(hash) || [];
          linksForHash.push(link);
          linkMap.set(hash, linksForHash);
        }

        const trackedSections = [];
        for (const hash of linkMap.keys()) {
          const id = hash.slice(1);
          let element = document.getElementById(id);

          if (!element && window.CSS && typeof window.CSS.escape === 'function') {
            element = document.querySelector(`#${window.CSS.escape(id)}`);
          }

          if (element) {
            trackedSections.push({ hash, element });
          }
        }

        if (trackedSections.length === 0) {
          return;
        }

        const getTopbarOffset = () => {
          const rawValue = getComputedStyle(document.documentElement)
            .getPropertyValue('--topbar-height')
            .trim();
          const parsedValue = Number.parseFloat(rawValue);
          return Number.isFinite(parsedValue) ? parsedValue : 0;
        };

        const activationOffset = () => getTopbarOffset() + 16;

        let activeHash = '';

        const setActiveHash = (nextHash) => {
          if (!nextHash || nextHash === activeHash) {
            return;
          }

          activeHash = nextHash;

          for (const [hash, links] of linkMap.entries()) {
            const isActive = hash === activeHash;
            for (const link of links) {
              link.classList.toggle('is-active', isActive);
              if (isActive) {
                link.setAttribute('aria-current', 'location');
              } else {
                link.removeAttribute('aria-current');
              }
            }
          }
        };

        const getVisibleHash = () => {
          const threshold = activationOffset();
          let currentHash = trackedSections[0].hash;

          for (const section of trackedSections) {
            const sectionTop = section.element.getBoundingClientRect().top;
            if (sectionTop <= threshold) {
              currentHash = section.hash;
            } else {
              break;
            }
          }

          return currentHash;
        };

        let framePending = false;
        const scheduleUpdate = () => {
          if (framePending) {
            return;
          }

          framePending = true;
          window.requestAnimationFrame(() => {
            framePending = false;
            setActiveHash(getVisibleHash());
          });
        };

        const initialHash = normalizeHash(window.location.hash);
        if (initialHash && linkMap.has(initialHash)) {
          setActiveHash(initialHash);
        } else {
          setActiveHash(getVisibleHash());
        }

        window.addEventListener('scroll', scheduleUpdate, { passive: true });
        window.addEventListener('resize', scheduleUpdate);
        window.addEventListener('hashchange', () => {
          const nextHash = normalizeHash(window.location.hash);
          if (nextHash && linkMap.has(nextHash)) {
            setActiveHash(nextHash);
            return;
          }

          scheduleUpdate();
        });
      })();
    </script>
  </body>
</html>
